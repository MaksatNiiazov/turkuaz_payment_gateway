APP_ENV=development
DEFAULT_PAYMENT_PROVIDER=mkassa
# Optional routing by integration key owner.
# Example: PAYMENT_PROVIDER_BY_INTEGRATION=1c:odengi,site:mkassa,pos:odengi
PAYMENT_PROVIDER_BY_INTEGRATION=

# MKassa API
MKASSA_BASE_URL=https://api.mkassa.kg
MKASSA_API_KEY=replace-with-cashier-or-partner-api-key

# O!Dengi / O!Bank API
# Keep ODENGI_PASSWORD quoted in real .env files if it contains # or other shell chars.
ODENGI_BASE_URL=https://mw-api-test.dengi.kg/api/json/json.php
ODENGI_SID=replace-with-merchant-sid
ODENGI_PASSWORD='replace-with-merchant-api-password'
ODENGI_API_VERSION=1005
ODENGI_LANG=ru
ODENGI_TEST=1
ODENGI_CURRENCY=KGS
ODENGI_RESULT_URL=https://your-domain.example/api/v1/webhooks/odengi

# Required protection for this microservice API.
# We issue these keys ourselves. External systems send only the key:
# X-Integration-Key: <key>
# Format: integration_name:key,integration_name_2:key_2
# Example: INTEGRATION_KEYS=1c:secret-for-1c,site:secret-for-site,pos:secret-for-pos
INTEGRATION_KEYS=1c:replace-with-1c-key,site:replace-with-site-key,pos:replace-with-pos-key

# Optional private key for the React/admin web service.
# Leave empty when admin traffic is already protected by the deployment boundary.
PAYMENT_ADMIN_API_KEY=

# Identity API used by the payment admin login and backend Bearer-token validation.
IDENTITY_API_URL=http://127.0.0.1:8500/api/v1

# Persistence for transactions, webhook events, and audit events.
# Current default for local, demo, and first production runs:
DATABASE_URL=sqlite:///./data/payment_gateway.db
# Keep true for local/docker auto-setup. In stricter environments, run migrations
# before deploy and set this to false.
AUTO_CREATE_SCHEMA=true

# MKassa may take up to 15 seconds to answer status requests according to the PDF.
REQUEST_TIMEOUT_CONNECT=5
REQUEST_TIMEOUT_READ=20
REQUEST_TIMEOUT_WRITE=10
REQUEST_TIMEOUT_POOL=5
REQUEST_MAX_RETRIES=2
REQUEST_RETRY_BASE_SECONDS=0.3
