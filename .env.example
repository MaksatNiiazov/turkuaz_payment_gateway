APP_ENV=development

# MKassa API
MKASSA_BASE_URL=https://api.mkassa.kg
MKASSA_API_KEY=replace-with-cashier-or-partner-api-key

# Optional protection for this microservice API.
# We issue these keys ourselves. External systems send only the key:
# X-Integration-Key: <key>
# Format: integration_name:key,integration_name_2:key_2
# Example: INTEGRATION_KEYS=1c:secret-for-1c,site:secret-for-site,pos:secret-for-pos
INTEGRATION_KEYS=

# Single-key mode. If set, it is treated as integration_name "default".
INTEGRATION_KEY=

# Optional protection for incoming MKassa callbacks.
# If set, accept either ?secret=<value>, X-MKassa-Webhook-Secret, or X-Webhook-Secret.
# Leave empty if MKassa cannot send a shared secret.
WEBHOOK_SHARED_SECRET=

# Local persistence for transactions and webhook events.
DATABASE_URL=sqlite:///./data/mbank_integration.db

# MKassa may take up to 15 seconds to answer status requests according to the PDF.
REQUEST_TIMEOUT_CONNECT=5
REQUEST_TIMEOUT_READ=20
REQUEST_TIMEOUT_WRITE=10
REQUEST_TIMEOUT_POOL=5
REQUEST_MAX_RETRIES=2
REQUEST_RETRY_BASE_SECONDS=0.3
