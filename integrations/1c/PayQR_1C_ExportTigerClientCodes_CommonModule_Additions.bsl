////////////////////////////////////////////////////////////////////////////////
// Добавить в общий модуль PayQR_ЗагрузкаОплат.
//
// Процедура выгружает покупателей из группы НАЛИЧКА вместе с доп. реквизитом
// "Tiger Код Клиента" в CSV.
////////////////////////////////////////////////////////////////////////////////

&НаКлиенте
Процедура PayQR_ВыгрузитьПокупателейВТаблицу() Экспорт

	ТекстCSV = PayQR_СформироватьCSVКодовTiger();

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Сохранить выгрузку кодов Tiger";
	Диалог.Фильтр = "CSV (*.csv)|*.csv";
	Диалог.ПолноеИмяФайла = "Контрагенты_Tiger_Коды.csv";

	Если НЕ Диалог.Выбрать() Тогда
		Возврат;
	КонецЕсли;

	Запись = Новый ЗаписьТекста(Диалог.ПолноеИмяФайла, КодировкаТекста.UTF8);
	Запись.Записать(ТекстCSV);
	Запись.Закрыть();

	Сообщить("PayQR: выгрузка кодов Tiger сохранена: " + Диалог.ПолноеИмяФайла);

КонецПроцедуры

&НаСервере
Функция PayQR_СформироватьCSVКодовTiger()

	ИмяДополнительногоРеквизита = "Tiger Код Клиента";
	КодГруппыНаличка = "00-000007";
	ГруппаНаличка = PayQR_НайтиГруппуКонтрагентовПоКоду(КодГруппыНаличка);

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Контрагенты.Код КАК Код1С,
		|	Контрагенты.Наименование КАК Наименование,
		|	Контрагенты.НаименованиеПолное КАК ПолноеНаименование,
		|	Контрагенты.ИНН КАК ИНН,
		|	Контрагенты.Родитель.Наименование КАК Родитель,
		|	ДопРеквизиты.Значение КАК TigerКодКлиента
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК ДопРеквизиты
		|		ПО ДопРеквизиты.Ссылка = Контрагенты.Ссылка
		|			И ДопРеквизиты.Свойство.Наименование = &ИмяДополнительногоРеквизита
		|ГДЕ
		|	НЕ Контрагенты.ЭтоГруппа
		|	И Контрагенты.ПометкаУдаления = ЛОЖЬ";

	Если ГруппаНаличка <> Неопределено Тогда
		Запрос.Текст = Запрос.Текст + Символы.ПС
			+ "		|	И Контрагенты.Ссылка В ИЕРАРХИИ(&ГруппаНаличка)";
		Запрос.УстановитьПараметр("ГруппаНаличка", ГруппаНаличка);
	КонецЕсли;

	Запрос.Текст = Запрос.Текст + Символы.ПС
		+ "		|УПОРЯДОЧИТЬ ПО
		|	Контрагенты.Код";

	Запрос.УстановитьПараметр("ИмяДополнительногоРеквизита", ИмяДополнительногоРеквизита);

	Выборка = Запрос.Выполнить().Выбрать();

	ТекстCSV = Символ(65279)
		+ "Код1С;Наименование;ПолноеНаименование;ИНН;Родитель;TigerКодКлиента"
		+ Символы.ПС;

	Пока Выборка.Следующий() Цикл

		ТекстCSV = ТекстCSV
			+ PayQR_CSV(Выборка.Код1С) + ";"
			+ PayQR_CSV(Выборка.Наименование) + ";"
			+ PayQR_CSV(Выборка.ПолноеНаименование) + ";"
			+ PayQR_CSV(Выборка.ИНН) + ";"
			+ PayQR_CSV(Выборка.Родитель) + ";"
			+ PayQR_CSV(Выборка.TigerКодКлиента)
			+ Символы.ПС;

	КонецЦикла;

	Возврат ТекстCSV;

КонецФункции

&НаСервере
Функция PayQR_НайтиГруппуКонтрагентовПоКоду(КодГруппы)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Контрагенты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ПометкаУдаления = ЛОЖЬ
		|	И Контрагенты.ЭтоГруппа = ИСТИНА
		|	И Контрагенты.Код = &КодГруппы";

	Запрос.УстановитьПараметр("КодГруппы", КодГруппы);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

&НаСервере
Функция PayQR_CSV(Значение)

	Если Значение = NULL Или Значение = Неопределено Тогда
		СтрокаЗначения = "";
	Иначе
		СтрокаЗначения = СокрЛП(Строка(Значение));
	КонецЕсли;

	СтрокаЗначения = СтрЗаменить(СтрокаЗначения, """", """""");

	Возврат """" + СтрокаЗначения + """";

КонецФункции
