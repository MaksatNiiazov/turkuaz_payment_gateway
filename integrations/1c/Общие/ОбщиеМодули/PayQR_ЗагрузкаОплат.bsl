////////////////////////////////////////////////////////////////////////////////
// ОбщийМодуль.PayQR_ЗагрузкаОплат
//
// Общий модуль 1С для загрузки успешных оплат из PaymentGateway.
//
// Рекомендуемые свойства общего модуля:
// - Сервер: Да
// - Вызов сервера: Да, если процедура будет запускаться из формы кнопкой
// - Клиент: Нет
//
// Точка входа для регламентного задания и ручной кнопки:
//   PayQR_ЗагрузитьУспешныеОплаты();
//
// Идемпотентность первого этапа хранится в комментарии платежного поручения:
//   PayQR paymentId=<paymentId>
//
// Это не меняет структуру базы 1С. Для более строгого учета позже можно
// заменить поиск по комментарию на регистр сведений.
//
// Если процедура отправила в PaymentGateway ошибку, событие переходит в error
// и не вернется в pending до админского reset.
////////////////////////////////////////////////////////////////////////////////

Процедура PayQR_ЗагрузитьУспешныеОплаты() Экспорт

	Попытка
		PayQR_ПроверитьНастройкиИнтеграции();

		КоличествоУспешно = 0;
		КоличествоОшибок = 0;
		ОбработанныеСобытия = Новый Соответствие;

		Пока Истина Цикл

			События = PayQR_ПолучитьСобытияОплат(
				PayQR_Настройки.PayQR_РазмерПакетаЗагрузкиОплат()
			);
			Если События = Неопределено Или События.Количество() = 0 Тогда
				Прервать;
			КонецЕсли;

			КоличествоНовыхСобытий = 0;

			Для Каждого Событие Из События Цикл

				EventId = PayQR_ПолучитьСвойствоСтрокой(Событие, "id");
				Если Не ЗначениеЗаполнено(EventId) Тогда
					Продолжить;
				КонецЕсли;

				Если ОбработанныеСобытия.Получить(EventId) <> Неопределено Тогда
					Продолжить;
				КонецЕсли;

				ОбработанныеСобытия.Вставить(EventId, Истина);
				КоличествоНовыхСобытий = КоличествоНовыхСобытий + 1;

				Результат = PayQR_ОбработатьСобытиеОплаты(Событие);
				Если Результат.Success Тогда
					КоличествоУспешно = КоличествоУспешно + 1;
				Иначе
					КоличествоОшибок = КоличествоОшибок + 1;
				КонецЕсли;

				PayQR_ОтправитьРезультатОбработки(Событие, Результат);

			КонецЦикла;

			Если КоличествоНовыхСобытий = 0 Тогда
				Прервать;
			КонецЕсли;

		КонецЦикла;

		Сообщить("Загрузка оплат PayQR завершена. Успешно: " + КоличествоУспешно
			+ ", ошибок: " + КоличествоОшибок + ".");

	Исключение
		Сообщить("Ошибка загрузки оплат PayQR: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

Функция PayQR_ОбработатьСобытиеОплаты(Событие)

	Попытка

		ДанныеОплаты = Неопределено;
		Если Не Событие.Свойство("event_payload", ДанныеОплаты) Или ДанныеОплаты = Неопределено Тогда
			Возврат PayQR_РезультатОшибки("В событии нет event_payload.");
		КонецЕсли;

		PaymentId = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "paymentId");
		InvoiceId = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "invoiceId");
		PaymentCode = НРег(PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "paymentCode"));

		Если Не ЗначениеЗаполнено(PaymentId) Тогда
			Возврат PayQR_РезультатОшибки("В событии нет paymentId.");
		КонецЕсли;

		УжеСозданныйДокумент = PayQR_НайтиДокументОплатыПоPaymentId(PaymentId);
		Если УжеСозданныйДокумент <> Неопределено Тогда
			Возврат PayQR_РезультатУспеха(Строка(УжеСозданныйДокумент));
		КонецЕсли;

		Если Не ЗначениеЗаполнено(InvoiceId) Тогда
			Возврат PayQR_РезультатОшибки("В событии нет invoiceId.");
		КонецЕсли;

		Реализация = PayQR_НайтиРеализациюПоInvoiceId(InvoiceId);
		Если Реализация = Неопределено Тогда
			Возврат PayQR_РезультатОшибки("Реализация с invoiceId " + InvoiceId + " не найдена.");
		КонецЕсли;

		ОшибкаПроверки = PayQR_ПроверитьДанныеОплаты(ДанныеОплаты, Реализация);
		Если ЗначениеЗаполнено(ОшибкаПроверки) Тогда
			Возврат PayQR_РезультатОшибки(ОшибкаПроверки);
		КонецЕсли;

		БанковскийСчетИлиКасса = PayQR_СчетИлиКассаПоКодуОплаты(PaymentCode);
		Если БанковскийСчетИлиКасса = Неопределено Тогда
			Возврат PayQR_РезультатОшибки("Не настроен счет/касса для paymentCode " + PaymentCode + ".");
		КонецЕсли;

		ДокументОплаты = PayQR_СоздатьДокументОплаты(Реализация, БанковскийСчетИлиКасса, ДанныеОплаты, PaymentId);
		Если ДокументОплаты = Неопределено Тогда
			Возврат PayQR_РезультатОшибки("Документ оплаты PayQR не создан.");
		КонецЕсли;

		Возврат PayQR_РезультатУспеха(Строка(ДокументОплаты));

	Исключение
		Возврат PayQR_РезультатОшибки(ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция PayQR_ПолучитьСобытияОплат(Лимит)

	АдресСервера = PayQR_АдресСервера();
	Заголовки = PayQR_ЗаголовкиHTTP();
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
	Соединение = Новый HTTPСоединение(АдресСервера, 443,,,,, ЗащищенноеСоединение);

	Запрос = Новый HTTPЗапрос("/api/v1/local/1c/payment-events/pending?limit=" + Лимит, Заголовки);
	Ответ = Соединение.Получить(Запрос);

	Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
		Сообщить("Очередь оплат PayQR не получена. Код ответа: " + Ответ.КодСостояния
			+ ". Ответ: " + Ответ.ПолучитьТелоКакСтроку());
		Возврат Неопределено;
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
	Возврат ПрочитатьJSON(ЧтениеJSON);

КонецФункции

Процедура PayQR_ОтправитьРезультатОбработки(Событие, Результат)

	EventId = PayQR_ПолучитьСвойствоСтрокой(Событие, "id");
	Если Не ЗначениеЗаполнено(EventId) Тогда
		Сообщить("Не удалось отправить результат PayQR: в событии нет id.");
		Возврат;
	КонецЕсли;

	ДанныеЗапроса = Новый Структура;
	ДанныеЗапроса.Вставить("success", Результат.Success);
	Если Результат.Success Тогда
		ДанныеЗапроса.Вставить("one_c_document_id", Результат.OneCDocumentId);
	Иначе
		ДанныеЗапроса.Вставить("error_message", Результат.ErrorMessage);
	КонецЕсли;

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ДанныеЗапроса);
	ТелоJSON = ЗаписьJSON.Закрыть();

	АдресСервера = PayQR_АдресСервера();
	Заголовки = PayQR_ЗаголовкиHTTP();
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
	Соединение = Новый HTTPСоединение(АдресСервера, 443,,,,, ЗащищенноеСоединение);

	Запрос = Новый HTTPЗапрос("/api/v1/local/1c/payment-events/" + EventId + "/result", Заголовки);
	Запрос.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
		Сообщить("Результат PayQR не отправлен. Код ответа: " + Ответ.КодСостояния
			+ ". Ответ: " + Ответ.ПолучитьТелоКакСтроку());
	КонецЕсли;

КонецПроцедуры

Функция PayQR_НайтиДокументОплатыПоPaymentId(PaymentId)

	Если Не ЗначениеЗаполнено(PaymentId) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПлатежноеПоручение.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПлатежноеПоручениеВходящее КАК ПлатежноеПоручение
		|ГДЕ
		|	ПлатежноеПоручение.ПометкаУдаления = ЛОЖЬ
		|	И ПлатежноеПоручение.Комментарий ПОДОБНО &МеткаPaymentId
		|УПОРЯДОЧИТЬ ПО
		|	ПлатежноеПоручение.Дата УБЫВ";
	Запрос.УстановитьПараметр("МеткаPaymentId", "%" + PayQR_МеткаPaymentId(PaymentId) + "%");

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция PayQR_НайтиРеализациюПоInvoiceId(InvoiceId)

	Попытка
		УИД = Новый УникальныйИдентификатор(InvoiceId);
		Ссылка = Документы.РеализацияТоваровУслуг.ПолучитьСсылку(УИД);
		Если ЗначениеЗаполнено(Ссылка) И Не Ссылка.Пустая() Тогда
			Возврат Ссылка;
		КонецЕсли;
	Исключение
		Возврат Неопределено;
	КонецПопытки;

	Возврат Неопределено;

КонецФункции

Функция PayQR_СчетИлиКассаПоКодуОплаты(PaymentCode)

	// paymentCode приходит из печатного QR:
	// - mbank
	// - obank
	// - qr_3
	// - qr_4
	//
	// В каждой базе 1С эти коды должны указывать на локальный банковский счет.
	// GUID счета через PaymentGateway не передается специально.

	НаименованиеСчета = PayQR_НаименованиеСчетаПоКодуОплаты(PaymentCode);
	Если Не ЗначениеЗаполнено(НаименованиеСчета) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат PayQR_НайтиБанковскийСчетПоНаименованию(НаименованиеСчета);

КонецФункции

Функция PayQR_НаименованиеСчетаПоКодуОплаты(PaymentCode)

	Возврат PayQR_Настройки.PayQR_НаименованиеБанковскогоСчета(PaymentCode);

КонецФункции

Функция PayQR_СоздатьДокументОплаты(Реализация, БанковскийСчетИлиКасса, ДанныеОплаты, PaymentId)

	СуммаПлатежа = PayQR_СуммаОплаты(ДанныеОплаты);
	Если СуммаПлатежа <= 0 Тогда
		ВызватьИсключение "Сумма оплаты должна быть больше нуля.";
	КонецЕсли;

	НаименованиеСтатьиДДС = PayQR_Настройки.PayQR_НаименованиеСтатьиДДС();
	СтатьяДДС = PayQR_НайтиСтатьюДДС(НаименованиеСтатьиДДС);
	Если СтатьяДДС = Неопределено Тогда
		ВызватьИсключение "Не найдена статья ДДС: " + НаименованиеСтатьиДДС + ".";
	КонецЕсли;

	ДокументОбъект = Документы.ПлатежноеПоручениеВходящее.СоздатьДокумент();
	ДокументОбъект.Дата = PayQR_ДатаОплаты(ДанныеОплаты);
	PayQR_ЗаполнитьВидОперацииОплатыОтПокупателя(ДокументОбъект);
	ДокументОбъект.Организация = Реализация.Организация;
	ДокументОбъект.Контрагент = Реализация.Контрагент;
	ДокументОбъект.ДоговорКонтрагента = Реализация.ДоговорКонтрагента;
	ДокументОбъект.БанковскийСчет = БанковскийСчетИлиКасса;
	ДокументОбъект.ДокументОснование = Реализация;
	ДокументОбъект.Комментарий = PayQR_КомментарийОплаты(ДанныеОплаты, PaymentId);

	PayQR_ЗаполнитьВходящиеРеквизиты(ДокументОбъект, ДанныеОплаты, PaymentId);
	PayQR_ЗаполнитьВалюту(ДокументОбъект, Реализация);
	PayQR_ЗаполнитьСчетРасчетов3210(ДокументОбъект);
	PayQR_ЗаполнитьСуммуПлатежа(ДокументОбъект, СуммаПлатежа);
	PayQR_ЗаполнитьРасшифровкуПлатежа(ДокументОбъект, СтатьяДДС, СуммаПлатежа);

	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

	Возврат ДокументОбъект.Ссылка;

КонецФункции

Процедура PayQR_ЗаполнитьВходящиеРеквизиты(ДокументОбъект, ДанныеОплаты, PaymentId)

	НомерВходящегоДокумента = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "providerPaymentId");
	Если Не ЗначениеЗаполнено(НомерВходящегоДокумента) Тогда
		НомерВходящегоДокумента = PaymentId;
	КонецЕсли;

	Если ЗначениеЗаполнено(НомерВходящегоДокумента) Тогда
		Попытка
			ДокументОбъект.НомерВходящегоДокумента = Лев(НомерВходящегоДокумента, 50);
		Исключение
		КонецПопытки;
	КонецЕсли;

	Попытка
		ДокументОбъект.ДатаВходящегоДокумента = ДокументОбъект.Дата;
	Исключение
	КонецПопытки;

	Попытка
		ДокументОбъект.ВидОплаты = ДокументОбъект.ВидОперации;
	Исключение
	КонецПопытки;

	Попытка
		ДокументОбъект.ПрямойКурс = Истина;
	Исключение
	КонецПопытки;

КонецПроцедуры

Функция PayQR_НайтиБанковскийСчетПоНаименованию(НаименованиеСчета)

	Если Не ЗначениеЗаполнено(НаименованиеСчета) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	БанковскиеСчета.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	БанковскиеСчета.ПометкаУдаления = ЛОЖЬ
		|	И БанковскиеСчета.Наименование ПОДОБНО &Наименование
		|УПОРЯДОЧИТЬ ПО
		|	БанковскиеСчета.Наименование";
	Запрос.УстановитьПараметр("Наименование", "%" + НаименованиеСчета + "%");

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция PayQR_НайтиСтатьюДДС(НаименованиеСтатьи)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СтатьиДДС.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СтатьиДвиженияДенежныхСредств КАК СтатьиДДС
		|ГДЕ
		|	СтатьиДДС.ПометкаУдаления = ЛОЖЬ
		|	И СтатьиДДС.Наименование = &НаименованиеСтатьи
		|УПОРЯДОЧИТЬ ПО
		|	СтатьиДДС.Наименование";
	Запрос.УстановитьПараметр("НаименованиеСтатьи", НаименованиеСтатьи);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Процедура PayQR_ЗаполнитьРасшифровкуПлатежа(ДокументОбъект, СтатьяДДС, СуммаПлатежа)

	Попытка
		ДокументОбъект.РасшифровкаПлатежа.Очистить();
		СтрокаРасшифровки = ДокументОбъект.РасшифровкаПлатежа.Добавить();
		СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
		СтрокаРасшифровки.СуммаПлатежа = СуммаПлатежа;
		СтрокаРасшифровки.СуммаВзаиморасчетов = СуммаПлатежа;
	Исключение
		ВызватьИсключение "Не удалось заполнить РасшифровкаПлатежа: " + ОписаниеОшибки();
	КонецПопытки;

КонецПроцедуры

Процедура PayQR_ЗаполнитьВидОперацииОплатыОтПокупателя(ДокументОбъект)

	ВидОперации = PayQR_НайтиВидОперацииПлатежногоПоручения("Оплата от покупателя");
	Если ЗначениеЗаполнено(ВидОперации) Тогда
		ДокументОбъект.ВидОперации = ВидОперации;
		Возврат;
	КонецЕсли;

	ВызватьИсключение "Не найден вид операции платежного поручения: Оплата от покупателя.";

КонецПроцедуры

Функция PayQR_НайтиВидОперацииПлатежногоПоручения(ПредставлениеВидаОперации)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 50
		|	ПлатежноеПоручение.ВидОперации КАК ВидОперации
		|ИЗ
		|	Документ.ПлатежноеПоручениеВходящее КАК ПлатежноеПоручение
		|ГДЕ
		|	ПлатежноеПоручение.ПометкаУдаления = ЛОЖЬ
		|УПОРЯДОЧИТЬ ПО
		|	ПлатежноеПоручение.Дата УБЫВ";

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если СокрЛП(Строка(Выборка.ВидОперации)) = ПредставлениеВидаОперации Тогда
			Возврат Выборка.ВидОперации;
		КонецЕсли;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Процедура PayQR_ЗаполнитьВалюту(ДокументОбъект, Реализация)

	Валюта = Неопределено;

	Попытка
		Валюта = Реализация.ВалютаДокумента;
	Исключение
	КонецПопытки;

	Если Не ЗначениеЗаполнено(Валюта) Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ДокументОбъект.ВалютаДокумента = Валюта;
	Исключение
	КонецПопытки;

	Попытка
		ДокументОбъект.ВалютаРасчетов = Валюта;
	Исключение
	КонецПопытки;

	Попытка
		ДокументОбъект.КурсВзаиморасчетов = 1;
	Исключение
	КонецПопытки;

	Попытка
		ДокументОбъект.КратностьВзаиморасчетов = 1;
	Исключение
	КонецПопытки;

КонецПроцедуры

Процедура PayQR_ЗаполнитьСчетРасчетов3210(ДокументОбъект)

	Попытка
		ДокументОбъект.СчетРасчетов = ПланыСчетов.Хозрасчетный.НайтиПоКоду(
			PayQR_Настройки.PayQR_КодСчетаРасчетов()
		);
	Исключение
		// В разных конфигурациях реквизит может называться иначе или заполняться автоматически.
	КонецПопытки;

