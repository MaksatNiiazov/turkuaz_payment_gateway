Функция PayQR_СуммаОплаты(ДанныеОплаты)

	AmountTyiyn = 0;
	Если ДанныеОплаты.Свойство("amountTyiyn", AmountTyiyn)
		И ЗначениеЗаполнено(AmountTyiyn) Тогда
		Возврат Окр(Число(AmountTyiyn) / 100, 2);
	КонецЕсли;

	Amount = 0;
	Если ДанныеОплаты.Свойство("amount", Amount)
		И ЗначениеЗаполнено(Amount) Тогда
		Возврат Окр(Число(Amount), 2);
	КонецЕсли;

	Возврат 0;

КонецФункции

Функция PayQR_ПроверитьДанныеОплаты(ДанныеОплаты, Реализация)

	Валюта = ВРег(PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "currency"));
	ОжидаемаяВалюта = ВРег(PayQR_Настройки.PayQR_КодВалюты());
	Если Валюта <> ОжидаемаяВалюта Тогда
		Возврат "Неподдерживаемая валюта оплаты: " + Валюта + ". Ожидается " + ОжидаемаяВалюта + ".";
	КонецЕсли;

	СуммаОплаты = PayQR_СуммаОплаты(ДанныеОплаты);
	Если СуммаОплаты <= 0 Тогда
		Возврат "Сумма оплаты должна быть больше нуля.";
	КонецЕсли;

	// QR создается на сумму реализации. Не допускаем проведения оплаты на
	// другую сумму. Если в вашей конфигурации поддерживаются частичные оплаты,
	// замените эту проверку на контроль остатка взаиморасчетов.
	Попытка
		СуммаРеализации = Окр(Реализация.СуммаДокумента, 2);
		РазницаСумм = СуммаОплаты - СуммаРеализации;
		Если СуммаРеализации > 0
			И (РазницаСумм > 0.01 Или РазницаСумм < -0.01) Тогда
			Возврат "Сумма оплаты " + Формат(СуммаОплаты, "ЧДЦ=2")
				+ " не совпадает с суммой реализации " + Формат(СуммаРеализации, "ЧДЦ=2") + ".";
		КонецЕсли;
	Исключение
		Возврат "Не удалось прочитать сумму реализации: " + ОписаниеОшибки();
	КонецПопытки;

	Возврат "";

КонецФункции

Функция PayQR_ДатаОплаты(ДанныеОплаты)

	СтрокаДаты = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "paidAt");
	Если Не ЗначениеЗаполнено(СтрокаДаты) Тогда
		Возврат ТекущаяДата();
	КонецЕсли;

	Попытка
		Если СтрДлина(СтрокаДаты) < 19 Тогда
			Возврат ТекущаяДата();
		КонецЕсли;

		ГодОплаты = Число(Лев(СтрокаДаты, 4));
		МесяцОплаты = Число(Сред(СтрокаДаты, 6, 2));
		ДеньОплаты = Число(Сред(СтрокаДаты, 9, 2));
		ЧасОплаты = Число(Сред(СтрокаДаты, 12, 2));
		МинутаОплаты = Число(Сред(СтрокаДаты, 15, 2));
		СекундаОплаты = Число(Сред(СтрокаДаты, 18, 2));

		Возврат Дата(
			ГодОплаты,
			МесяцОплаты,
			ДеньОплаты,
			ЧасОплаты,
			МинутаОплаты,
			СекундаОплаты
		);
	Исключение
		Возврат ТекущаяДата();
	КонецПопытки;

КонецФункции

Функция PayQR_КомментарийОплаты(ДанныеОплаты, PaymentId)

	InvoiceId = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "invoiceId");
	InvoiceNumber = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "invoiceNumber");
	PaymentCode = PayQR_ПолучитьСвойствоСтрокой(ДанныеОплаты, "paymentCode");

	Комментарий = PayQR_МеткаPaymentId(PaymentId);

	Если ЗначениеЗаполнено(InvoiceId) Тогда
		Комментарий = Комментарий + Символы.ПС + "invoiceId=" + InvoiceId;
	КонецЕсли;

	Если ЗначениеЗаполнено(InvoiceNumber) Тогда
		Комментарий = Комментарий + Символы.ПС + "invoiceNumber=" + InvoiceNumber;
	КонецЕсли;

	Если ЗначениеЗаполнено(PaymentCode) Тогда
		Комментарий = Комментарий + Символы.ПС + "paymentCode=" + PaymentCode;
	КонецЕсли;

	Возврат Комментарий;

КонецФункции

Функция PayQR_МеткаPaymentId(PaymentId)

	Возврат "PayQR paymentId=" + СокрЛП(Строка(PaymentId));

КонецФункции

Функция PayQR_РезультатУспеха(OneCDocumentId)

	Результат = Новый Структура;
	Результат.Вставить("Success", Истина);
	Результат.Вставить("OneCDocumentId", OneCDocumentId);
	Результат.Вставить("ErrorMessage", "");
	Возврат Результат;

КонецФункции

Функция PayQR_РезультатОшибки(ErrorMessage)

	Результат = Новый Структура;
	Результат.Вставить("Success", Ложь);
	Результат.Вставить("OneCDocumentId", "");
	Результат.Вставить("ErrorMessage", ErrorMessage);
	Возврат Результат;

КонецФункции

Функция PayQR_ПолучитьСвойствоСтрокой(СтруктураИсточник, ИмяСвойства)

	ЗначениеСвойства = "";
	Если СтруктураИсточник <> Неопределено
		И СтруктураИсточник.Свойство(ИмяСвойства, ЗначениеСвойства)
		И ЗначениеЗаполнено(ЗначениеСвойства) Тогда
		Возврат СокрЛП(Строка(ЗначениеСвойства));
	КонецЕсли;

	Возврат "";

КонецФункции

Функция PayQR_ЗаголовкиHTTP()

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("X-Integration-Key", PayQR_ИнтеграционныйКлюч());

	Возврат Заголовки;

КонецФункции

Функция PayQR_АдресСервера()

	Возврат PayQR_Настройки.PayQR_АдресСервера();

КонецФункции

Функция PayQR_ИнтеграционныйКлюч()

	Возврат PayQR_Настройки.PayQR_ИнтеграционныйКлюч();

КонецФункции

Процедура PayQR_ПроверитьНастройкиИнтеграции()

	Ключ = PayQR_ИнтеграционныйКлюч();
	Если Не ЗначениеЗаполнено(Ключ) Или Ключ = "ВСТАВЬТЕ_АКТУАЛЬНЫЙ_КЛЮЧ_1С" Тогда
		ВызватьИсключение "Не задан X-Integration-Key для PayQR. Настройте защищенное хранилище 1С.";
	КонецЕсли;

КонецПроцедуры
