Функция PayQR_АдресСервера() Экспорт

	Возврат "payments.turkuaztrade.kg";

КонецФункции

Функция PayQR_ИнтеграционныйКлюч() Экспорт

	// Вставьте только секретную часть ключа 1С, без "1c:".
	Возврат "ВСТАВЬТЕ_АКТУАЛЬНЫЙ_КЛЮЧ_1С";

КонецФункции

Функция PayQR_НаименованиеБанковскогоСчета(PaymentCode) Экспорт

	// Указывайте точное наименование счета этой базы 1С.
	// Пустое значение безопасно: импорт такой оплаты завершится ошибкой и не
	// проведет документ на неверный счет.
	PaymentCode = НРег(СокрЛП(Строка(PaymentCode)));
	Если PaymentCode = "obank" Тогда
		Возврат "ФОАО ""О!Банк-Юг""";
	ИначеЕсли PaymentCode = "mbank" Тогда
		Возврат ""; // Заполнить реальным счетом MBank.
	ИначеЕсли PaymentCode = "qr_3" Тогда
		Возврат ""; // Заполнить реальным банковским счетом или кассой.
	ИначеЕсли PaymentCode = "qr_4" Тогда
		Возврат ""; // Заполнить реальным банковским счетом или кассой.
	КонецЕсли;

	Возврат "";

КонецФункции

Функция PayQR_НаименованиеСтатьиДДС() Экспорт

	Возврат "Денежные средства от реализации продукции, работ, услуг";

КонецФункции

Функция PayQR_КодСчетаРасчетов() Экспорт

	Возврат "3210";

КонецФункции

Функция PayQR_КодВалюты() Экспорт

	Возврат "KGS";

КонецФункции

Функция PayQR_ИмяДопРеквизитаTigerКодКлиента() Экспорт

	Возврат "Tiger Код Клиента";

КонецФункции

Функция PayQR_РазмерПакетаЗагрузкиОплат() Экспорт

	Возврат 20;

КонецФункции
