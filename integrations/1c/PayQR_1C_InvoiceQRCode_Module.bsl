////////////////////////////////////////////////////////////////////////////////
// PayQR_1C_InvoiceQRCode_Module.bsl
//
// Что сделать в расширении 1С:
//
// 1. Найти старый блок в PayQR_ПечатьНакладнойQR:
//
//    // Вывод QR.
//    ...
//    ТабличныйДокумент.Вывести(ОбластьQRCode);
//
// 2. Полностью заменить старый блок на одну строку:
//
//    PayQR_ВывестиQRCodeПоНастройкам(
//        ТабличныйДокумент,
//        Макет,
//        Шапка.Ссылка,
//        Шапка.Номер,
//        ДанныеПечати.ИтогоКОплате,
//        СокрЛП(Строка(Шапка.Контрагент.Код)));
//
// 3. Старую функцию PayQR_ПолучитьКартинкуQRCode удалить или не использовать.
//
// 4. Вставить функции ниже в этот же общий модуль расширения.
//
// Важно:
// - В PayQR_ИнтеграционныйКлюч() нужно вставить ОДИН актуальный ключ для 1С.
// - В 1С больше не нужно хранить отдельные ключи для MBank/O!Bank.
// - Порядок, подписи, включение/отключение QR теперь настраиваются в веб-админке
//   PaymentGateway во вкладке "QR для 1С".
//
// Ограничение текущего макета:
// - Этот код заполняет первые 2 существующих слота:
//   КартинкаQRCode и КартинкаQRCodeOBank.
// - Если в макет добавить слоты КартинкаQRCode3 / КартинкаQRCode4, код заполнит
//   и их тоже.
// - Для подписей можно добавить параметры макета:
//   ПодписьQRCode, ПодписьQRCodeOBank, ПодписьQRCode3, ПодписьQRCode4.
////////////////////////////////////////////////////////////////////////////////

Процедура PayQR_ВывестиQRCodeПоНастройкам(ТабличныйДокумент, Макет, ДокументСсылка, НомерДокумента, СуммаДокумента, КодКлиентаTiger)

	ОбластьQRCode = Макет.ПолучитьОбласть("QRCode");

	ЭлементыQR = PayQR_ПолучитьСписокQRCode(ДокументСсылка, НомерДокумента, СуммаДокумента, КодКлиентаTiger);
	Если ЭлементыQR = Неопределено Или ЭлементыQR.Количество() = 0 Тогда
		ТабличныйДокумент.Вывести(ОбластьQRCode);
		Возврат;
	КонецЕсли;

	АдресСервера = PayQR_АдресСервера();
	Заголовки = PayQR_ЗаголовкиHTTP();
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
	Соединение = Новый HTTPСоединение(АдресСервера, 443,,,,, ЗащищенноеСоединение);

	НомерСлота = 1;
	Для Каждого ЭлементQR Из ЭлементыQR Цикл

		Если НомерСлота > 4 Тогда
			Сообщить("Получено больше 4 QR-кодов. Добавьте дополнительные области/картинки в макет 1С.");
			Прервать;
		КонецЕсли;

		ПутьКартинки = "";
		ПодписьQRCode = "";

		ЭлементQR.Свойство("image_path", ПутьКартинки);
		ЭлементQR.Свойство("label", ПодписьQRCode);

		Если Не ЗначениеЗаполнено(ПутьКартинки) Тогда
			НомерСлота = НомерСлота + 1;
			Продолжить;
		КонецЕсли;

		ДвоичныеДанныеQRCode = PayQR_ПолучитьКартинкуQRCodeПоПути(Соединение, Заголовки, ПутьКартинки);
		Если ЗначениеЗаполнено(ДвоичныеДанныеQRCode) Тогда
			PayQR_ЗаполнитьСлотQRCode(ОбластьQRCode, НомерСлота, ДвоичныеДанныеQRCode, ПодписьQRCode);
		КонецЕсли;

		НомерСлота = НомерСлота + 1;

	КонецЦикла;

	ТабличныйДокумент.Вывести(ОбластьQRCode);

КонецПроцедуры

Функция PayQR_ПолучитьСписокQRCode(ДокументСсылка, НомерДокумента, СуммаДокумента, КодКлиентаTiger)

	Попытка

		АдресСервера = PayQR_АдресСервера();
		Заголовки = PayQR_ЗаголовкиHTTP();
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
		Соединение = Новый HTTPСоединение(АдресСервера, 443,,,,, ЗащищенноеСоединение);

		СуммаВТыйынах = Окр(СуммаДокумента * 100, 0);
		КодКлиентаTiger = СокрЛП(Строка(КодКлиентаTiger));
		Если НЕ ЗначениеЗаполнено(КодКлиентаTiger) Тогда
			Сообщить("QR оплаты не создан: не заполнен код клиента Tiger.");
			Возврат Неопределено;
		КонецЕсли;

		ДанныеЗапроса = Новый Структура;
		ДанныеЗапроса.Вставить("amount", СуммаВТыйынах);
		ДанныеЗапроса.Вставить("invoice_id", Строка(ДокументСсылка.УникальныйИдентификатор()));
		ДанныеЗапроса.Вставить("invoice_number", Строка(НомерДокумента));
		ДанныеЗапроса.Вставить("client_code", КодКлиентаTiger);
		ДанныеЗапроса.Вставить("source", "1c");

		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ДанныеЗапроса);
		ТелоJSON = ЗаписьJSON.Закрыть();

		ЗапросСоздания = Новый HTTPЗапрос("/api/v1/invoice/qr-codes", Заголовки);
		ЗапросСоздания.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8);

		ОтветСоздания = Соединение.ОтправитьДляОбработки(ЗапросСоздания);
		Если ОтветСоздания.КодСостояния < 200 Или ОтветСоздания.КодСостояния >= 300 Тогда
			Сообщить("QR оплаты не создан. Код ответа: " + ОтветСоздания.КодСостояния
				+ ". Ответ: " + ОтветСоздания.ПолучитьТелоКакСтроку());
			Возврат Неопределено;
		КонецЕсли;

		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ОтветСоздания.ПолучитьТелоКакСтроку());
		ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON);

		ЭлементыQR = Неопределено;
		Если НЕ ДанныеОтвета.Свойство("items", ЭлементыQR) Тогда
			Сообщить("QR оплаты создан, но список items не получен.");
			Возврат Неопределено;
		КонецЕсли;

		Возврат ЭлементыQR;

	Исключение
		Сообщить("Ошибка получения списка QR оплаты: " + ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

Функция PayQR_ПолучитьКартинкуQRCodeПоПути(Соединение, Заголовки, ПутьКартинки)

	Попытка

		Если Лев(ПутьКартинки, 1) <> "/" Тогда
			ПутьКартинки = "/" + ПутьКартинки;
		КонецЕсли;

		ЗапросКартинки = Новый HTTPЗапрос(ПутьКартинки, Заголовки);
		ОтветКартинки = Соединение.Получить(ЗапросКартинки);

		Если ОтветКартинки.КодСостояния < 200 Или ОтветКартинки.КодСостояния >= 300 Тогда
			Сообщить("Картинка QR оплаты не получена. Код ответа: " + ОтветКартинки.КодСостояния);
			Возврат Неопределено;
		КонецЕсли;

		Возврат ОтветКартинки.ПолучитьТелоКакДвоичныеДанные();

	Исключение
		Сообщить("Ошибка получения картинки QR оплаты: " + ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

Процедура PayQR_ЗаполнитьСлотQRCode(ОбластьQRCode, НомерСлота, ДвоичныеДанныеQRCode, ПодписьQRCode)

	Если НомерСлота = 1 Тогда

		ОбластьQRCode.Рисунки.КартинкаQRCode.Линия = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
		ОбластьQRCode.Рисунки.КартинкаQRCode.Картинка = Новый Картинка(ДвоичныеДанныеQRCode);
		PayQR_УстановитьПодписьQRCode(ОбластьQRCode, "ПодписьQRCode", ПодписьQRCode);

	ИначеЕсли НомерСлота = 2 Тогда

		ОбластьQRCode.Рисунки.КартинкаQRCodeOBank.Линия = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
		ОбластьQRCode.Рисунки.КартинкаQRCodeOBank.Картинка = Новый Картинка(ДвоичныеДанныеQRCode);
		PayQR_УстановитьПодписьQRCode(ОбластьQRCode, "ПодписьQRCodeOBank", ПодписьQRCode);

	ИначеЕсли НомерСлота = 3 Тогда

		Попытка
			ОбластьQRCode.Рисунки.КартинкаQRCode3.Линия = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
			ОбластьQRCode.Рисунки.КартинкаQRCode3.Картинка = Новый Картинка(ДвоичныеДанныеQRCode);
			PayQR_УстановитьПодписьQRCode(ОбластьQRCode, "ПодписьQRCode3", ПодписьQRCode);
		Исключение
			Сообщить("В макете нет рисунка КартинкаQRCode3.");
		КонецПопытки;

	ИначеЕсли НомерСлота = 4 Тогда

		Попытка
			ОбластьQRCode.Рисунки.КартинкаQRCode4.Линия = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии);
			ОбластьQRCode.Рисунки.КартинкаQRCode4.Картинка = Новый Картинка(ДвоичныеДанныеQRCode);
			PayQR_УстановитьПодписьQRCode(ОбластьQRCode, "ПодписьQRCode4", ПодписьQRCode);
		Исключение
			Сообщить("В макете нет рисунка КартинкаQRCode4.");
		КонецПопытки;

	КонецЕсли;

КонецПроцедуры

Процедура PayQR_УстановитьПодписьQRCode(ОбластьQRCode, ИмяПараметра, ПодписьQRCode)

	Если Не ЗначениеЗаполнено(ПодписьQRCode) Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ОбластьQRCode.Параметры[ИмяПараметра] = ПодписьQRCode;
	Исключение
		// В макете может еще не быть параметра подписи. Это не должно ломать печать QR.
	КонецПопытки;

КонецПроцедуры

Функция PayQR_ЗаголовкиHTTP()

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("X-Integration-Key", PayQR_ИнтеграционныйКлюч());

	Возврат Заголовки;

КонецФункции

Функция PayQR_АдресСервера()

	Возврат "payments.turkuaztrade.kg";

КонецФункции

Функция PayQR_ИнтеграционныйКлюч()

	// TODO: вставить один актуальный integration key для 1С.
	// Не нужно вставлять отдельные ключи MBank/O!Bank.
	Возврат "ВСТАВЬТЕ_ИНТЕГРАЦИОННЫЙ_КЛЮЧ_1С";

КонецФункции
